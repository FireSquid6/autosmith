# Fleet dev environment — loaded by ./dev.sh. Committable: no secrets here
# (secrets belong in .env.local, which is gitignored).

# Origin the fleet-client server reverse-proxies /bridge/* to. Must match the
# port in fleet-bridge-config.yaml. The browser's Eden treaty talks to the
# same-origin /bridge prefix, which forwards here.
BUN_PUBLIC_BRIDGE_URL=http://localhost:4800

# Authentication: the bridge is secure by default (config.requireAuth). It accepts
# a human session cookie (via `fleet bridge create-user` + the /login page) OR the
# shared service token as a machine principal. Ships and the CLI/agents present the
# same service token. Put the real value in .env.local (gitignored), NOT here:
#   FLEET_SERVICE_TOKEN=<a long random string, shared by bridge + ships + CLI>
# Bootstrap the first web user once the bridge is running:
#   fleet bridge create-user <username>        # or the /login first-run bootstrap
